#!/bin/sh
# ai-devkit: reject commit messages that break the Conventional Commits standard.
# Installed globally through core.hooksPath (see setup.mjs).
# Merge, revert, fixup and squash commits are skipped.

MAX_LEN=72
TYPES='feat|fix|refactor|perf|docs|test|build|ci|chore|infra|revert'

header=$(head -n1 "$1")

case "$header" in
  Merge*|Revert*|fixup!*|squash!*|'#'*) exit 0 ;;
esac

if ! printf '%s' "$header" | grep -Eq "^($TYPES)\([a-z0-9._/-]+\)!?: .+"; then
  echo "" >&2
  echo "✗ Commit rejected: not a valid Conventional Commit." >&2
  echo "" >&2
  echo "  Received : $header" >&2
  echo "  Expected : <type>(<scope>): <description>   (scope REQUIRED)" >&2
  echo "  Valid types: $(echo "$TYPES" | tr '|' ' ')" >&2
  echo "" >&2
  echo "  Example: feat(auth): add refresh token rotation" >&2
  echo "" >&2
  exit 1
fi

desc=$(printf '%s' "$header" | sed -E "s/^($TYPES)\([a-z0-9._/-]+\)!?: //")
if printf '%s' "$desc" | grep -q '[A-Z]'; then
  echo "" >&2
  echo "✗ Commit rejected: the subject must be entirely lowercase." >&2
  echo "" >&2
  echo "  Received : $header" >&2
  echo "  Fix to   : $(printf '%s' "$header" | tr '[:upper:]' '[:lower:]')" >&2
  echo "" >&2
  exit 1
fi

len=$(printf '%s' "$header" | wc -m | tr -d ' ')
if [ "$len" -gt "$MAX_LEN" ]; then
  echo "" >&2
  echo "✗ Commit rejected: subject is $len characters, limit is $MAX_LEN." >&2
  echo "  $header" >&2
  echo "" >&2
  exit 1
fi

exit 0
